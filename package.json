{
  "name": "track-dl",
  "version": "1.0.0",
  "description": "Search Spotify, download from YouTube, merge metadata with album art",
  "main": "index.js",
  "bin": {
    "track-dl": "index.js"
  },
  "scripts": {
    "start": "node index.js",
    "update-yt-dlp": "node -e \"const fs=require('fs');const https=require('https');const file=fs.createWriteStream('yt-dlp.exe');https.get('https://github.com/yt-dlp/yt-dlp/releases/latest/download/yt-dlp.exe',(r)=>r.pipe(file).on('finish',()=>console.log('Updated yt-dlp.exe')))\"",
    "test": "echo \\\"Error: no test specified\\\" && exit 1"
  },
  "keywords": ["track-dl", "spotify", "youtube", "download", "music", "mp3"],
  "author": "",
  "license": "MIT",
  "dependencies": {
    "spotify-web-api-node": "^5.0.2",
    "fluent-ffmpeg": "^2.1.3",
    "inquirer": "^8.2.7",
    "dotenv": "^16.4.7",
    "axios": "^1.7.9"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/eaeoz/track-dl.git"
  }
}
