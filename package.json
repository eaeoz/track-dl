{
  "name": "track-dl",
  "version": "1.0.5",
  "description": "Search iTunes, download from YouTube, merge metadata with album art",
  "main": "index.js",
  "bin": {
    "track-dl": "index.js"
  },
  "scripts": {
    "start": "node index.js",
    "postinstall": "node -e \"const fs=require('fs');const https=require('https');const path=require('path');const file=path.join(__dirname,'yt-dlp.exe');function download(u){https.get(u,(r)=>{if(r.statusCode===302&&r.headers.location){download(r.headers.location)}else{r.pipe(fs.createWriteStream(file)).on('finish',()=>console.log('Downloaded yt-dlp.exe'))}}).on('error',()=>fs.existsSync(file)&&fs.unlinkSync(file))}if(!fs.existsSync(file)){download('https://github.com/yt-dlp/yt-dlp/releases/latest/download/yt-dlp.exe')}\"",
    "update-yt-dlp": "node -e \"const fs=require('fs');const https=require('https');const file=fs.createWriteStream('yt-dlp.exe');https.get('https://github.com/yt-dlp/yt-dlp/releases/latest/download/yt-dlp.exe',(r)=>r.pipe(file).on('finish',()=>console.log('Updated yt-dlp.exe')))\"",
    "test": "echo \\\"Error: no test specified\\\" && exit 1"
  },
  "keywords": ["track-dl", "itunes", "youtube", "download", "music", "mp3"],
  "author": "",
  "license": "MIT",
  "dependencies": {
    "axios": "^1.7.9",
    "inquirer": "^8.2.7",
    "ffmpeg-static": "^5.2.0"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/eaeoz/track-dl.git"
  }
}
